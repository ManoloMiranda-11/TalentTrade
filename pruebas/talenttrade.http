@urlBase = http://localhost:4000
@tokenPrincipal = PEGA_AQUI_EL_TOKEN_DE_ANA
@tokenOtraPersona = PEGA_AQUI_EL_TOKEN_DE_CARLOS
@usuarioOtraPersonaId = PEGA_AQUI_EL_ID_DE_CARLOS
@habilidadIdOferta = PEGA_AQUI_UN_ID_DE_HABILIDAD_QUE_OFREZCAS
@habilidadIdDeseada = PEGA_AQUI_UN_ID_DE_HABILIDAD_QUE_QUIERAS
@coincidenciaId = PEGA_AQUI_UN_ID_DE_COINCIDENCIA
@conversacionId = PEGA_AQUI_UN_ID_DE_CONVERSACION
@sesionId = PEGA_AQUI_UN_ID_DE_SESION
@habilidadUsuarioId = PEGA_AQUI_UN_ID_DE_HABILIDAD_USUARIO
@disponibilidadId = PEGA_AQUI_UN_ID_DE_DISPONIBILIDAD
@profesorId = PEGA_AQUI_UN_ID_DE_PROFESOR
@aprendizId = PEGA_AQUI_UN_ID_DE_APRENDIZ

### Estado del servicio
GET {{urlBase}}/salud

### Registro de Ana
POST {{urlBase}}/api/autenticacion/registro
Content-Type: application/json

{
  "correo": "ana@talenttrade.es",
  "contrasena": "123456",
  "nombre": "Ana"
}

### Registro de Carlos
POST {{urlBase}}/api/autenticacion/registro
Content-Type: application/json

{
  "correo": "carlos@talenttrade.es",
  "contrasena": "123456",
  "nombre": "Carlos"
}

### Inicio de sesion de Ana
POST {{urlBase}}/api/autenticacion/inicio-sesion
Content-Type: application/json

{
  "correo": "ana@talenttrade.es",
  "contrasena": "123456"
}

### Inicio de sesion de Carlos
POST {{urlBase}}/api/autenticacion/inicio-sesion
Content-Type: application/json

{
  "correo": "carlos@talenttrade.es",
  "contrasena": "123456"
}

### Perfil actual de Ana
GET {{urlBase}}/api/usuarios/yo
Authorization: Bearer {{tokenPrincipal}}

### Editar perfil de Ana
PATCH {{urlBase}}/api/usuarios/yo
Authorization: Bearer {{tokenPrincipal}}
Content-Type: application/json

{
  "biografia": "Me encanta aprender y ensenar con ejemplos sencillos.",
  "ciudad": "Madrid"
}

### Editar perfil de Carlos
PATCH {{urlBase}}/api/usuarios/yo
Authorization: Bearer {{tokenOtraPersona}}
Content-Type: application/json

{
  "biografia": "Me gusta aprender practicando con otras personas.",
  "ciudad": "Valencia"
}

### Listar habilidades
GET {{urlBase}}/api/habilidades

### Ana ofrece una habilidad
POST {{urlBase}}/api/habilidades/yo
Authorization: Bearer {{tokenPrincipal}}
Content-Type: application/json

{
  "habilidadId": "{{habilidadIdOferta}}",
  "tipo": "OFRECER",
  "nivel": "AVANZADO"
}

### Ana quiere aprender otra habilidad
POST {{urlBase}}/api/habilidades/yo
Authorization: Bearer {{tokenPrincipal}}
Content-Type: application/json

{
  "habilidadId": "{{habilidadIdDeseada}}",
  "tipo": "APRENDER",
  "nivel": "MEDIO"
}

### Carlos ofrece la habilidad que Ana quiere aprender
POST {{urlBase}}/api/habilidades/yo
Authorization: Bearer {{tokenOtraPersona}}
Content-Type: application/json

{
  "habilidadId": "{{habilidadIdDeseada}}",
  "tipo": "OFRECER",
  "nivel": "MEDIO"
}

### Carlos quiere aprender la habilidad que Ana ofrece
POST {{urlBase}}/api/habilidades/yo
Authorization: Bearer {{tokenOtraPersona}}
Content-Type: application/json

{
  "habilidadId": "{{habilidadIdOferta}}",
  "tipo": "APRENDER",
  "nivel": "INICIAL"
}

### Eliminar habilidad del usuario
DELETE {{urlBase}}/api/habilidades/yo/{{habilidadUsuarioId}}
Authorization: Bearer {{tokenPrincipal}}

### Descubrir intercambios compatibles para Ana
GET {{urlBase}}/api/coincidencias/descubrir
Authorization: Bearer {{tokenPrincipal}}

### Crear solicitud de intercambio de Ana a Carlos
POST {{urlBase}}/api/coincidencias
Authorization: Bearer {{tokenPrincipal}}
Content-Type: application/json

{
  "receptorId": "{{usuarioOtraPersonaId}}",
  "habilidadOfrecidaId": "{{habilidadIdOferta}}",
  "habilidadDeseadaId": "{{habilidadIdDeseada}}"
}

### Listar coincidencias de Ana
GET {{urlBase}}/api/coincidencias/yo
Authorization: Bearer {{tokenPrincipal}}

### Carlos acepta la solicitud
PATCH {{urlBase}}/api/coincidencias/{{coincidenciaId}}/estado
Authorization: Bearer {{tokenOtraPersona}}
Content-Type: application/json

{
  "estado": "ACEPTADA"
}

### Ver conversacion
GET {{urlBase}}/api/mensajes/{{conversacionId}}
Authorization: Bearer {{tokenPrincipal}}

### Enviar mensaje
POST {{urlBase}}/api/mensajes/{{conversacionId}}
Authorization: Bearer {{tokenPrincipal}}
Content-Type: application/json

{
  "contenido": "Hola, te viene bien organizar una sesion esta semana?"
}

### Ver disponibilidad de Ana
GET {{urlBase}}/api/disponibilidad/yo
Authorization: Bearer {{tokenPrincipal}}

### Crear disponibilidad de Ana
POST {{urlBase}}/api/disponibilidad/yo
Authorization: Bearer {{tokenPrincipal}}
Content-Type: application/json

{
  "diaSemana": "MON",
  "horaInicio": "18:00",
  "horaFin": "20:00"
}

### Eliminar disponibilidad
DELETE {{urlBase}}/api/disponibilidad/yo/{{disponibilidadId}}
Authorization: Bearer {{tokenPrincipal}}

### Crear sesion
POST {{urlBase}}/api/sesiones
Authorization: Bearer {{tokenPrincipal}}
Content-Type: application/json

{
  "coincidenciaId": "{{coincidenciaId}}",
  "habilidadId": "{{habilidadIdOferta}}",
  "profesorId": "{{profesorId}}",
  "aprendizId": "{{aprendizId}}",
  "fechaProgramada": "2026-04-15T18:00:00.000Z",
  "duracionMinutos": 60
}

### Listar mis sesiones
GET {{urlBase}}/api/sesiones/yo
Authorization: Bearer {{tokenPrincipal}}

### Completar sesion
PATCH {{urlBase}}/api/sesiones/{{sesionId}}/estado
Authorization: Bearer {{tokenPrincipal}}
Content-Type: application/json

{
  "estado": "COMPLETADA"
}

### Crear valoracion
POST {{urlBase}}/api/valoraciones
Authorization: Bearer {{tokenOtraPersona}}
Content-Type: application/json

{
  "sesionId": "{{sesionId}}",
  "valoradoId": "{{profesorId}}",
  "puntuacion": 5,
  "comentario": "Muy buena experiencia."
}

### Ver valoraciones de Ana
GET {{urlBase}}/api/valoraciones/yo
Authorization: Bearer {{tokenPrincipal}}

